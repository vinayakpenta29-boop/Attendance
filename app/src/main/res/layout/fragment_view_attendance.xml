<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9">

    <!-- ✅ ONLY ONE CHILD -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- ===== Month Header ===== -->
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/salary_card_bg"
            android:padding="16dp"
            android:layout_margin="16dp"
            android:elevation="4dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/prevMonth"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/month_btn_bg"
                android:padding="10dp"
                android:layout_width="40dp"
                android:layout_height="40dp"/>

            <TextView
                android:id="@+id/monthText"
                android:text="March 2026"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#333"
                android:layout_weight="1"
                android:gravity="center"
                android:layout_width="0dp"
                android:layout_height="wrap_content"/>

            <ImageView
                android:id="@+id/nextMonth"
                android:src="@drawable/ic_arrow_forward"
                android:background="@drawable/month_btn_bg"
                android:padding="10dp"
                android:layout_width="40dp"
                android:layout_height="40dp"/>
        </LinearLayout>

        <!-- ===== MAIN CONTENT ===== -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ===== Calendar ===== -->
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/salary_card_bg"
                android:padding="14dp"
                android:layout_marginBottom="18dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Attendance Calendar"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#222"
                    android:paddingBottom="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TableLayout
                    android:id="@+id/tableLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="*"/>
            </LinearLayout>

            <!-- ===== History ===== -->
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/salary_card_bg"
                android:padding="14dp"
                android:layout_marginBottom="18dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Attendance History"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#222"
                    android:paddingBottom="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TableLayout
                    android:id="@+id/summaryTable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="*"
                    android:background="#F1F3F6"
                    android:padding="6dp"/>
            </LinearLayout>

            <!-- ===== Payroll ===== -->
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/salary_card_bg"
                android:padding="14dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Payroll Summary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#222"
                    android:paddingBottom="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TableLayout
                    android:id="@+id/payrollTable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="*"
                    android:background="#F1F3F6"
                    android:padding="6dp"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
